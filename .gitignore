# Python bytecode caches. Created by host CPython any time we run
# `python3 -m py_compile`, importable scripts under firmware/scripts/,
# or any IDE's auto-import. They are tagged with the host interpreter
# version (cpython-3xx) and are useless to the badge (which runs
# MicroPython with a different bytecode magic). The build pipeline
# (firmware/scripts/generate_startup_files.py) already skips them at
# bake / mirror time, so we just want them out of git.
__pycache__/
*.pyc
*.pyo

# vcpkg
vcpkg_installed/

# debug information files
*.dwo

# test output & cache
Testing/
.cache/
/firmware/micropython/micropython_repo
Temporal-Badge.code-workspace
hardware/design-log.md
/hardware/DELTA
/ignition/secure_provision/__pycache__
/ignition/flash_worker/__pycache__
/hardware/CHARLIE/pcb/Temporal-Badge-CHARLIE-backups
/hardware/CHARLIE/pcb/Temporal-Badge-backups
/hardware/CHARLIE/pcb/Temporal-Badge-CHARLIE/Temporal-Badge-BRAVO-backups
/hardware/BRAVO/pcb/Temporal-Badge-BRAVO-backups
/hardware/BRAVO/pcb/Temporal-Badge-backups
/hardware/ALPHA/Temporal-Badge-backups
/firmware/build/sketch/.mp_src_tmp
/firmware/build/sketch/Firmware-0308-modular
/firmware/build/sketch/.venv

# Release-bundled assets — too big for git, fetched in CI from
# fallback_url (see release-assets/manifest.json) and attached to
# every GitHub release. Used by the badge's Asset Library.
/firmware/initial_filesystem/doom1.wad
/firmware/initial_filesystem/*.wad
/.asset-cache/
/artifacts/

# Build mirror of firmware/initial_filesystem/ for PlatformIO uploadfs.
# Regenerated by firmware/scripts/generate_startup_files.py.
firmware/data/
/firmware/.venv-flashgui
